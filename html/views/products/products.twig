<div class="w-full bg-white rounded-2xl shadow-2xl mb-6 p-16">
    <table class="table-auto w-full" id="products-table">
        <thead>
            <tr>
                {% for header in products_header %}
                <th class="px-4 py-2">{{ header }}</th>
                {% endfor %}
                <th class="px-4 py-2">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for product in products_data %}
            <tr>
                {% for key, value in product %}
                <td class="border px-4 py-2">
                    {% if key == 'rating' %}
                    {% for i in 0..value - 1 %}
                    <span>&#9733;</span> <!-- This is a star symbol -->
                    {% endfor %}
                    {% elseif key == 'comments' %}
                    {{ value|length }} <!-- This will output the number of comments -->
                    {% else %}
                    {{ value }}
                    {% endif %}
                </td>
                {% endfor %}
                <td class="border flex flex-row items-center justify-center">
                    <button
                        class="mt-3 inline-flex justify-center rounded-md bg-blue-100 px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-blue-500 sm:mt-0 sm:w-auto transition duration-500 ease-in-out mr-2"
                        data-bs-toggle="modal" data-bs-target="#deleteModal">Edit</button>
                    <button
                        class="inline-flex justify-center rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 sm:ml-3 sm:w-auto transition duration-500 ease-in-out"
                        data-bs-toggle="modal" data-bs-target="#editModal">Delete</button>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<!-- Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Edit</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                ...
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary">Save changes</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Delete</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                ...
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary">Save changes</button>
            </div>
        </div>
    </div>
</div>